{
  "route": {
    "rules": [
      {
        "action": "sniff"
      },
      {
        "protocol": "dns",
        "action": "hijack-dns"
      },
      {
        "rule_set": [
          "Claude",
          "JetBrains",
          "Gemini",
          "OpenAI"
        ],
        "outbound": "AI"
      },
      {
        "rule_set": [
          "Google",
          "Meta",
          "X"
        ],
        "outbound": "GLOBAL"
      },
      {
        "rule_set": [
          "Spotify"
        ],
        "outbound": "HK"
      },
      {
        "rule_set": [
          "Twitch",
          "Bahamut"
        ],
        "outbound": "Streaming Media"
      },
      {
        "rule_set": "PayPal",
        "outbound": "PayPal"
      },
      {
        "rule_set": [
          "Microsoft",
          "Apple"
        ],
        "outbound": "GLOBAL"
      },
            {
        "network": "icmp",
        "outbound": "direct"
      },
      {
        "ip_is_private": true,
        "outbound": "direct"
      },
      {
        "rule_set": [
          "Geosite-CN",
          "Geoip-CN"
        ],
        "outbound": "Direct"
      }
    ],
    "rule_set": [
      {
        "tag": "Geoip-CN",
        "type": "remote",
        "format": "binary",
        "url": "https://raw.githubusercontent.com/Loyalsoldier/geoip/release/srs/cn.srs",
        "update_interval": "12h",
        "download_detour": "HK"
      },
      {
        "tag": "Geosite-CN",
        "type": "remote",
        "format": "binary",
        "url": "https://raw.githubusercontent.com/lyc8503/sing-box-rules/rule-set-geosite/geosite-cn.srs",
        "update_interval": "12h",
        "download_detour": "HK"
      },
      {
        "tag": "PayPal",
